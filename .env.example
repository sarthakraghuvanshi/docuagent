# Copy to .env and adjust. Docker Compose reads this file automatically.

# --- Postgres (metadata: documents, jobs) ---
POSTGRES_USER=docuagent
POSTGRES_PASSWORD=docuagent
POSTGRES_DB=docuagent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://docuagent:docuagent@postgres:5432/docuagent

# --- Redis (RQ job queue for ingestion workers) ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant (vector store) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=docuagent_chunks

# --- Ollama (local LLM, OpenAI-compatible) ---
OLLAMA_BASE_URL=http://ollama:11434
LLM_PROVIDER=ollama          # ollama | vertex | openai (Phase 7 adds the latter two)
LLM_MODEL=llama3.1:8b

# --- Embeddings ---
EMBEDDING_PROVIDER=local     # local (sentence-transformers) | vertex | openai
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# --- Reranker (Phase 3) ---
RERANK_MODEL=BAAI/bge-reranker-base

# --- Self-healing loop thresholds (Phase 4) ---
GRADE_THRESHOLD=0.7
MAX_ATTEMPTS=3

# --- Retrieval defaults ---
RETRIEVAL_TOP_K=5

# --- Langfuse (tracing, Phase 4 wires this in) ---
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
